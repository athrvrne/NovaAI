# ──────────────────────────────────────────────
# NovaAI — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# App
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./novaai.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/novaai

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=novaai2026

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE_MINUTES=480

# Anthropic (for Summarizer Agent)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SendGrid (for email delivery)
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=hello@novaai.com
SENDGRID_FROM_NAME=NovaAI

# News sources (comma-separated RSS feeds)
RSS_FEEDS=https://feeds.feedburner.com/oreilly/radar,https://www.theverge.com/rss/ai-artificial-intelligence/index.xml,https://techcrunch.com/category/artificial-intelligence/feed/

# Pipeline settings
PIPELINE_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_RUN=100
MIN_RELEVANCE_SCORE=0.6
